{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Foundry",
  "version": "1.18.0",
  "identifier": "com.foundry.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Foundry",
        "width": 900,
        "height": 620,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "untrusted comment: minisign public key: E18DD436D8FF7E52\nRWRSfv/YNtSN4QiwbALydILwUrm+nDp/icMckT8FAszI94wbv3QlcJvO",
      "endpoints": [
        "https://github.com/theodaguier/foundry/releases/latest/download/latest.json"
      ]
    }
  }
}
