# Foundry — Environment Variables
# Copy this file to .env and fill in the values.
# The .env file is loaded automatically by the Tauri backend at startup.

# Supabase (auth + telemetry sync)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# PostHog (analytics — optional, leave blank to disable)
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your_project_api_key
VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
