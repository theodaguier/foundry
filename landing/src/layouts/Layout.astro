    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Build AU and VST3 audio plugins on macOS — without the boilerplate. Currently in private beta." />
    <title>{title}</title>
    {import.meta.env.PUBLIC_POSTHOG_PROJECT_TOKEN && (
      <script define:vars={{ key: import.meta.env.PUBLIC_POSTHOG_PROJECT_TOKEN, host: import.meta.env.PUBLIC_POSTHOG_HOST ?? 'https://eu.i.posthog.com' }}>
