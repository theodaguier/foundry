---
interface Props {
  title?: string;
}
const { title = "Foundry — Private Beta" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Build AU and VST3 audio plugins on macOS — without the boilerplate. Currently in private beta." />
    <title>{title}</title>
    <style>
      @font-face {
        font-family: "ArchitypeStedelijk";
        src: url("/fonts/ArchitypeStedelijkW00.ttf") format("truetype");
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "AzeretMono";
        src: url("/fonts/AzeretMono.ttf") format("truetype");
        font-weight: 100 900;
        font-style: normal;
        font-display: swap;
      }

      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html, body {
        height: 100%;
        width: 100%;
      }

      body {
        background-color: #161616;
        color: #c8c8c0;
        font-family: "AzeretMono", monospace;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
