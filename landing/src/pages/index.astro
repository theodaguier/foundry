          <path d="M1202.27 684.426C1240.61 684.007 1278.95 683.893 1317.29 684.084C1335.96 684.151 1355.55 683.334 1374.01 685.578C1383.13 686.497 1396.85 698.722 1399.96 707.002C1405.07 720.605 1403.8 742.375 1403.82 756.896L1403.7 818.562C1403.65 835.88 1403.6 853.735 1403.73 871.037C1403.96 900.642 1394.53 919.298 1362.14 921.1L1254.2 921.099C1233.78 921.114 1198.87 925.336 1181.24 914.251C1162.6 902.526 1164.59 878.839 1164.52 859.444L1164.47 809.086L1164.42 754.209C1164.39 722.931 1160.84 689.639 1202.27 684.426Z" fill="currentColor"/>
        </svg>
      </div>

      <!-- Heading -->
      <h1 class="title">Foundry</h1>

      <!-- Tagline -->
      <p class="tagline">
        You describe the sound. Foundry writes the C++,<br />
        builds it with JUCE, and installs it in your DAW&thinsp;&mdash;<br />
        AU and VST3 on macOS, VST3 on Windows.<br />
        No code. No boilerplate.
      </p>

      <!-- Email form -->
      <form class="form" id="waitlist-form" novalidate>
        <label for="email" class="sr-only">Email address</label>
        <div class="input-row" id="input-row">
          <input
            type="email"
            id="email"
            name="email"
            class="email-input"
            placeholder="your@email.com"
            autocomplete="email"
            inputmode="email"
            required
          />
          <button type="submit" class="submit-btn">
            Request access&nbsp;&rarr;
          </button>
        </div>
        <p class="disclaimer" id="form-message" aria-live="polite">
          No spam. We'll reach out when a spot opens.
        </p>
      </form>
    </div>
  </main>
</Layout>

<script>
  const form = document.getElementById("waitlist-form") as HTMLFormElement;
  const emailInput = document.getElementById("email") as HTMLInputElement;
  const message = document.getElementById("form-message") as HTMLParagraphElement;
  const inputRow = document.getElementById("input-row") as HTMLDivElement;

  emailInput.addEventListener("focus", () => inputRow.classList.add("focused"));
  emailInput.addEventListener("blur", () => inputRow.classList.remove("focused"));

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    if (!email) return;

    const btn = form.querySelector("button") as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = "Sending\u2026";

    try {
      const res = await fetch("/api/waitlist", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email }),
      });

      if (res.ok) {
        emailInput.value = "";
        message.textContent = "You\u2019re on the list. We\u2019ll be in touch.";
        btn.textContent = "Done";
      } else {
        throw new Error();
      }
    } catch {
      message.textContent = "Something went wrong. Try again.";
      btn.disabled = false;
      btn.textContent = "Request access\u00a0\u2192";
    }
  });
</script>

<style>
  main {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100dvh;
    padding: 2rem;
  }

  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 480px;
    width: 100%;
  }

  /* Logo */
  .logo-wrap {
    margin-bottom: 0.375rem;
  }

  .logo {
    display: block;
    color: #323230;
  }

  /* Title */
  .title {
    font-family: "ArchitypeStedelijk", serif;
    font-size: 1.375rem;
    font-weight: normal;
    color: #c8c8c0;
    letter-spacing: 0.08em;
    margin-bottom: 1.875rem;
  }

  /* Tagline */
  .tagline {
    font-family: "AzeretMono", monospace;
    font-size: 0.8125rem;
    color: #646460;
    line-height: 1.8;
    letter-spacing: 0.01em;
    margin-bottom: 2.25rem;
  }

  /* Form */
  .form {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.875rem;
  }

  .input-row {
    display: flex;
    align-items: center;
    width: 100%;
    border-bottom: 1px solid #2c2c2a;
    padding-bottom: 0.5rem;
    transition: border-color 0.2s ease;
  }

  .input-row.focused {
    border-color: #3e3e3a;
  }

  .email-input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    outline: none;
    font-family: "AzeretMono", monospace;
    font-size: 0.8125rem;
    color: #646460;
    caret-color: #c8c8c0;
    padding: 0;
  }

  .email-input::placeholder {
    color: #323230;
  }

  .email-input:focus {
    color: #a8a8a0;
  }

  .submit-btn {
    flex-shrink: 0;
    background: transparent;
    border: none;
    outline: none;
    cursor: pointer;
    font-family: "AzeretMono", monospace;
    font-size: 0.8125rem;
    color: #646460;
    white-space: nowrap;
    padding: 0;
    padding-left: 1rem;
    transition: color 0.15s ease;
  }

  .submit-btn:hover {
    color: #c8c8c0;
  }

  .submit-btn:focus-visible {
    outline: 1px solid #3e3e3a;
    outline-offset: 4px;
    border-radius: 2px;
  }

  .submit-btn:disabled {
    cursor: default;
    color: #323230;
  }

  .disclaimer {
    font-family: "AzeretMono", monospace;
    font-size: 0.75rem;
    color: #323230;
    letter-spacing: 0.01em;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
